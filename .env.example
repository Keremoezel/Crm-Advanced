# ============================================
# CRM-Advanced Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to git!

# ---- NuxtHub ----
NUXT_HUB_PROJECT_KEY=
NUXT_HUB_PROJECT_URL=

# ---- Authentication ----
NUXT_AUTH_SECRET=           # Random 32+ char string for session encryption
NUXT_AUTH_ORIGIN=           # e.g. http://localhost:3000

# ---- Microsoft Azure AD (Teams Integration) ----
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ---- Email (Newsletter / Notifications) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@power4.de

# ---- Application ----
NUXT_PUBLIC_APP_NAME=CRM-Advanced
NUXT_PUBLIC_DEFAULT_LOCALE=de-DE
